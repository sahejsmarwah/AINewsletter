# Copy this file to .env and fill in your own keys. Never commit .env itself.

# Free tier LLM for the editing phase
GROQ_API_KEY=

# Only needed if you swap to Gemini instead of / alongside Groq
GEMINI_API_KEY=

# Only needed once you add the product_hunt_server
PRODUCT_HUNT_TOKEN=

# Only needed once you add a search MCP server (e.g. Brave Search)
BRAVE_SEARCH_API_KEY=

# Gmail - populated after you run the OAuth flow once locally
GMAIL_CREDENTIALS_PATH=./mcp_servers/gmail_server/credentials.json
GMAIL_TOKEN_PATH=./mcp_servers/gmail_server/token.json

# Who receives the newsletter (comma-separated for multiple recipients)
NEWSLETTER_TO=
